{
  "name": "@fis/platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "docs:build": "python3 -m zensical build",
    "dev": "pnpm --filter @fis/worker dev",
    "deploy": "pnpm --filter @fis/worker run deploy",
    "mcp:dev": "pnpm --filter @fis/mcp dev",
    "mcp:deploy": "pnpm --filter @fis/mcp deploy",
    "mcp:oauth:smoke": "pnpm --filter @fis/mcp oauth:smoke",
    "mcp:smoke": "pnpm --filter @fis/mcp smoke",
    "skills:validate": "node scripts/validate-skills.mjs",
    "test": "pnpm docs:build && pnpm skills:validate && pnpm --filter @fis/worker test && pnpm --filter @fis/mcp test",
    "test:e2e": "playwright test",
    "typecheck": "pnpm --filter @fis/worker typecheck && pnpm --filter @fis/mcp typecheck",
    "db:migrate:local": "pnpm --filter @fis/worker db:migrate:local",
    "db:migrate:prod": "pnpm --filter @fis/worker db:migrate:prod"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
